import React from "react";
import { HomeButton } from "@/components/HomeButton";
import { BackButton } from "@/components/BackButton";
import { ThemeToggle } from "@/components/ThemeToggle";
import { Link } from "react-router-dom";
import { Map } from "lucide-react";
import { Button } from "@/components/ui/button";
import { MercyGuide } from "@/components/MercyGuide";

interface AppShellProps {
  children: React.ReactNode;
  bottomBar?: React.ReactNode;
  hideHeader?: boolean;
  mainClassName?: string;
  showMercyGuide?: boolean;
}

/**
 * AppShell - Centered layout container
 *
 * Current app routing already provides a global header band on non-admin pages.
 * So this shell must be SAFE BY DEFAULT:
 * - header hidden by default (prevents double headers)
 * - MercyGuide hidden by default (prevents duplicate guide mounts)
 *
 * Keeps:
 * - canonical 980px centered content frame
 * - defensive clamp for room renderers
 */
export function AppShell({
  children,
  bottomBar,
  hideHeader = true,
  mainClassName = "",
  showMercyGuide = false,
}: AppShellProps) {
  return (
    <div className="relative min-h-screen flex flex-col bg-background">
      <style>{`
        :root{
          --mb-page-max: 980px;
        }

        [data-mb-frame]{
          width: 100%;
          max-width: var(--mb-page-max);
          margin-left: auto;
          margin-right: auto;
          box-sizing: border-box;
        }

        [data-mb-frame] [data-mb-scope="room"]{
          width: 100% !important;
          max-width: 100% !important;
          margin-left: 0 !important;
          margin-right: 0 !important;
          box-sizing: border-box !important;
        }

        [data-mb-frame] [data-mb-scope="room"] [data-room-box]{
          width: 100% !important;
          max-width: 100% !important;
          margin-left: 0 !important;
          margin-right: 0 !important;
          box-sizing: border-box !important;
        }
      `}</style>

      {!hideHeader && (
        <header className="sticky top-0 z-40 w-full border-b border-border/40 bg-background/80 backdrop-blur-sm">
          <div className="mx-auto grid h-12 max-w-[980px] grid-cols-[auto,1fr,auto] items-center px-4">
            <div className="flex items-center gap-2">
              <HomeButton />
              <BackButton />
            </div>

            <div className="flex justify-center">
              <Link
                to="/"
                className="bg-gradient-to-r from-[hsl(var(--rainbow-magenta))] via-[hsl(var(--rainbow-purple))] to-[hsl(var(--rainbow-cyan))] bg-clip-text text-lg font-semibold tracking-tight text-transparent transition-opacity hover:opacity-80"
              >
                Mercy Blade
              </Link>
            </div>

            <div className="flex items-center justify-end gap-2">
              <ThemeToggle />
              <Button variant="ghost" size="sm" className="h-8 w-8 p-0" asChild>
                <Link to="/tiers" title="Tier Map" aria-label="Tier Map">
                  <Map className="h-4 w-4" />
                </Link>
              </Button>
            </div>
          </div>
        </header>
      )}

      <main className={`flex-1 ${mainClassName}`}>
        <div data-mb-frame className="px-4 py-4">
          {children}
        </div>
      </main>

      {bottomBar}

      {showMercyGuide ? <MercyGuide /> : null}
    </div>
  );
}

export function AppShellContent({
  children,
  className = "",
}: {
  children: React.ReactNode;
  className?: string;
}) {
  return (
    <div data-mb-frame className={`px-4 py-4 ${className}`}>
      {children}
    </div>
  );
}